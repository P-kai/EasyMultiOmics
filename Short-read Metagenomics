# EasyMultiOmics: Short-read metagenomic analysis workflow

    # Version: 1.02, 2026/04/30
    # Tested on CentOS 7 / Linux
    # Module: Short-read Metagenomics
    # Description: Raw data quality control, read-based taxonomic profiling, ARG annotation and quantification,
    #              metagenomic assembly, genome binning, bin quality assessment, bin taxonomy,
    #              SGB construction and SGB phylogenetic analysis.

# 0. Basic configuration

## 0.1 Set sample name and computational resources

    # Use the variable i to specify the sample name
    i=sample_name

    # Set the number of CPU threads
    threads=24

    # Define raw paired-end short-read input files
    raw_R1=${i}_R1.fastq.gz
    raw_R2=${i}_R2.fastq.gz

    # Create the main output directory
    outdir=${i}_short_read_metagenome
    mkdir -p ${outdir}

    # Enter the output directory
    cd ${outdir}

    # Create subdirectories for each analysis module
    mkdir -p 01_raw_qc
    mkdir -p 02_clean_reads
    mkdir -p 03_taxonomy
    mkdir -p 04_ARGs
    mkdir -p 05_assembly
    mkdir -p 06_binning
    mkdir -p 07_bin_qc
    mkdir -p 08_bin_taxonomy
    mkdir -p 09_SGBs
    mkdir -p 09_SGBs/MAGs
    mkdir -p 09_SGBs/repre_MAGs
    mkdir -p 09_SGBs/scripts
    mkdir -p 10_SGB_tree

    # Link raw data into the working directory
    ln -s ../${raw_R1} 01_raw_qc/${raw_R1}
    ln -s ../${raw_R2} 01_raw_qc/${raw_R2}

Explanation:

This section defines the sample name, CPU threads, paired-end input files and output directory. The input files are assumed to be Illumina paired-end short-read FASTQ files. The example uses compressed FASTQ format with the file names `${i}_R1.fastq.gz` and `${i}_R2.fastq.gz`.

## 0.2 Set database paths

    # Kraken2 / Bracken database
    KRAKEN2_DB=/path/to/kraken2_database

    # ARGs_OAP database and ARG classification structure file
    ARG_DB=/path/to/ARGs_OAP_database.fasta
    ARG_STRUCTURE=/path/to/ARGs_OAP_structure.txt

    # CheckM2 database
    CHECKM2_DB=/path/to/checkm2_database/uniref100.KO.1.dmnd

    # GTDB-Tk database
    GTDBTK_DB=/path/to/gtdbtk_database

    # PhyloPhlAn database and configuration file
    PHYLOPHLAN_DB=/path/to/phylophlan_database/phylophlan
    PHYLOPHLAN_CFG=/path/to/phylophlan_configs/supermatrix_aa.cfg

Explanation:

This section defines the database paths used by the workflow. Before running the workflow, all `/path/to/...` paths should be replaced with real database paths on your server.

# 1. Raw data quality control

## 1.1 Quality control and adapter trimming of paired-end short reads

    # Activate the conda environment containing fastp
    conda activate fastp

    # Perform quality control for paired-end short-read data
    fastp \
      -i 01_raw_qc/${raw_R1} \
      -I 01_raw_qc/${raw_R2} \
      -o 02_clean_reads/${i}_clean_R1.fastq.gz \
      -O 02_clean_reads/${i}_clean_R2.fastq.gz \
      -h 01_raw_qc/${i}_fastp.html \
      -j 01_raw_qc/${i}_fastp.json \
      -w ${threads}

Explanation:

This step removes adapters, trims low-quality bases and filters low-quality reads from paired-end short-read metagenomic data. The HTML and JSON reports generated by fastp can be used to evaluate raw data quality and the effect of filtering.

Main outputs:

    02_clean_reads/${i}_clean_R1.fastq.gz
    02_clean_reads/${i}_clean_R2.fastq.gz
    01_raw_qc/${i}_fastp.html
    01_raw_qc/${i}_fastp.json

## 1.2 Generate statistics for clean short reads

    # Activate conda environment containing seqkit
    conda activate seqkit

    # Generate read statistics for clean paired-end reads
    seqkit stats \
      -T \
      02_clean_reads/${i}_clean_R1.fastq.gz \
      02_clean_reads/${i}_clean_R2.fastq.gz \
      > 02_clean_reads/${i}_clean_seqkit_stats.tsv

Explanation:

This step summarizes the number of reads, total bases and read length information of the clean short-read data. These statistics are useful for checking sequencing depth and for downstream normalization if required.

Main output:

    02_clean_reads/${i}_clean_seqkit_stats.tsv

## 1.3 Convert clean FASTQ reads to FASTA format

    # Convert cleaned FASTQ files to FASTA format
    seqkit fq2fa \
      02_clean_reads/${i}_clean_R1.fastq.gz \
      > 02_clean_reads/${i}_clean_R1.fasta

    seqkit fq2fa \
      02_clean_reads/${i}_clean_R2.fastq.gz \
      > 02_clean_reads/${i}_clean_R2.fasta

    # Merge paired-end FASTA files for ARG annotation
    cat 02_clean_reads/${i}_clean_R1.fasta \
        02_clean_reads/${i}_clean_R2.fasta \
        > 02_clean_reads/${i}_clean_reads.fasta

Explanation:

Several ARG annotation workflows can use FASTA input. Therefore, the filtered paired-end FASTQ reads are converted to FASTA format and then merged into a single FASTA file for ARG annotation.

Main outputs:

    02_clean_reads/${i}_clean_R1.fasta
    02_clean_reads/${i}_clean_R2.fasta
    02_clean_reads/${i}_clean_reads.fasta

# 2. Read-based taxonomic profiling

## 2.1 Species annotation using Kraken2

    # Activate the conda environment containing Kraken2
    conda activate kraken2

    # Use Kraken2 for taxonomic classification of paired-end short reads
    kraken2 \
      --db ${KRAKEN2_DB} \
      --threads ${threads} \
      --paired \
      --gzip-compressed \
      --report 03_taxonomy/${i}_kraken2_report.txt \
      --output 03_taxonomy/${i}_kraken2_output.txt \
      02_clean_reads/${i}_clean_R1.fastq.gz \
      02_clean_reads/${i}_clean_R2.fastq.gz

Explanation:

Kraken2 provides a rapid k-mer-based taxonomic classification strategy for metagenomic reads. The report file summarizes the taxonomic composition of the short-read metagenome and can be used for downstream abundance estimation and visualization.

Main outputs:

    03_taxonomy/${i}_kraken2_report.txt
    03_taxonomy/${i}_kraken2_output.txt

## 2.2 Species-level abundance estimation using Bracken

    # Activate the conda environment containing Bracken
    conda activate bracken

    # Estimate species-level abundance based on Kraken2 results
    bracken \
      -d ${KRAKEN2_DB} \
      -i 03_taxonomy/${i}_kraken2_report.txt \
      -o 03_taxonomy/${i}_bracken_species.txt \
      -r 150 \
      -l S \
      -t 10

Explanation:

Bracken re-estimates species-level abundance from Kraken2 classification results. The parameter `-r 150` indicates that the expected read length is 150 bp and should be modified according to the actual sequencing read length. The parameter `-l S` means that abundance is estimated at the species level. The parameter `-t 10` is the minimum read threshold, not the number of CPU threads.

Main output:

    03_taxonomy/${i}_bracken_species.txt

# 3. ARG annotation and quantification

## 3.1 Prepare input files for ARGs_OAP

    # Activate the conda environment containing ARGs_OAP
    conda activate args_oap

    # Create ARGs_OAP output directories
    mkdir -p 04_ARGs/${i}_ARGs_OAP
    mkdir -p 04_ARGs/${i}_ARGs_OAP/stage_one
    mkdir -p 04_ARGs/${i}_ARGs_OAP/stage_two

Explanation:

This step prepares output directories for ARG annotation and quantification using ARGs_OAP. In this workflow, the merged clean-read FASTA file generated in the previous step is used as the input file.

Main input:

    02_clean_reads/${i}_clean_reads.fasta

## 3.2 Optional: build customized ARGs_OAP database

    # Use this step only when a customized ARG database is required
    # The database may contain nucleotide or amino acid sequences

    # args_oap make_db \
    #   -i /path/to/custom_database.fasta

Explanation:

This step is optional. If you want to use a customized antibiotic resistance gene database, you can build it using ARGs_OAP. If you are using a default or already prepared database, this step can be skipped.

## 3.3 Stage one: ARG annotation using ARGs_OAP

    # Perform ARG annotation using ARGs_OAP
    args_oap stage_one \
      -i 02_clean_reads/${i}_clean_reads.fasta \
      -o 04_ARGs/${i}_ARGs_OAP/stage_one \
      -f fa \
      -t ${threads} \
      --database ${ARG_DB}

Explanation:

This step performs ARG annotation by comparing clean metagenomic reads against the selected ARG database. The output of stage one is used as the input for ARG classification and quantification.

Main output directory:

    04_ARGs/${i}_ARGs_OAP/stage_one

## 3.4 Stage two: ARG classification and quantification using ARGs_OAP

    # Classify and quantify annotated ARGs
    args_oap stage_two \
      -i 04_ARGs/${i}_ARGs_OAP/stage_one \
      -o 04_ARGs/${i}_ARGs_OAP/stage_two \
      -t ${threads} \
      --database ${ARG_DB} \
      --structure1 ${ARG_STRUCTURE}

Explanation:

This step classifies and quantifies ARGs based on the annotation results from stage one. It usually generates ARG abundance tables and ARG classification profiles.

Main output directory:

    04_ARGs/${i}_ARGs_OAP/stage_two

Note:

Different ARGs_OAP versions may use slightly different command-line parameters. Before formal analysis, check the local help information using:

    args_oap -h
    args_oap stage_one -h
    args_oap stage_two -h

# 4. Metagenomic assembly

## 4.1 Assembly of short-read metagenome using MEGAHIT

    # Activate the conda environment containing MEGAHIT
    conda activate megahit

    # Assemble cleaned paired-end reads into metagenomic contigs
    megahit \
      -1 02_clean_reads/${i}_clean_R1.fastq.gz \
      -2 02_clean_reads/${i}_clean_R2.fastq.gz \
      -o 05_assembly/${i}_megahit \
      -t ${threads} \
      --min-contig-len 1000

    # Copy final assembly result to a simplified file name
    cp 05_assembly/${i}_megahit/final.contigs.fa \
       05_assembly/${i}_megahit_contigs.fasta

Explanation:

MEGAHIT is used for short-read metagenomic assembly. The parameter `--min-contig-len 1000` keeps contigs with length greater than or equal to 1000 bp, which is generally more suitable for downstream genome binning.

Main output:

    05_assembly/${i}_megahit_contigs.fasta

## 4.2 Assembly statistics

    # Activate conda environment containing seqkit
    conda activate seqkit

    # Generate assembly statistics
    seqkit stats \
      -a \
      -T \
      05_assembly/${i}_megahit_contigs.fasta \
      > 05_assembly/${i}_megahit_contigs_stats.tsv

Explanation:

This step summarizes the assembly result, including contig number, total assembly size, minimum length, maximum length and N50.

Main output:

    05_assembly/${i}_megahit_contigs_stats.tsv

# 5. Genome binning

## 5.1 Genome binning using MetaWRAP MetaBAT2

    # Activate the conda environment containing MetaWRAP
    conda activate metawrap

    # Perform genome binning using MetaWRAP with MetaBAT2
    metawrap binning \
      -o 06_binning/${i}_metawrap_metabat2 \
      -t ${threads} \
      -a 05_assembly/${i}_megahit_contigs.fasta \
      --metabat2 \
      02_clean_reads/${i}_clean_R1.fastq.gz \
      02_clean_reads/${i}_clean_R2.fastq.gz

    # Copy bins to a unified directory
    mkdir -p 06_binning/${i}_bins
    cp 06_binning/${i}_metawrap_metabat2/metabat2_bins/*.fa \
       06_binning/${i}_bins/

Explanation:

This step reconstructs metagenome-assembled genomes from assembled contigs. MetaWRAP calls MetaBAT2 for binning using contig composition and short-read coverage information.

Main output directory:

    06_binning/${i}_bins

# 6. Bin quality assessment using CheckM2

## 6.1 Assess MAG completeness and contamination

    # Activate the conda environment containing CheckM2
    conda activate checkm2

    # Configure CheckM2 database if required
    export CHECKM2DB=${CHECKM2_DB}

    # Evaluate MAG quality
    checkm2 predict \
      --threads ${threads} \
      --input 06_binning/${i}_bins \
      --output-directory 07_bin_qc/${i}_checkm2 \
      -x fa

Explanation:

CheckM2 estimates genome completeness and contamination for each MAG. These metrics are essential for selecting high-quality and medium-quality MAGs for taxonomic classification and SGB analysis.

Main output directory:

    07_bin_qc/${i}_checkm2

## 6.2 Select medium-quality and high-quality MAGs

    # Create output directories for selected MAGs
    mkdir -p 07_bin_qc/${i}_selected_MAGs
    mkdir -p 07_bin_qc/${i}_high_quality_MAGs

    # Select medium-quality MAGs:
    # completeness >= 50% and contamination <= 10%
    awk -F'\t' 'NR==1 {next} $2>=50 && $3<=10 {print $1}' \
      07_bin_qc/${i}_checkm2/quality_report.tsv \
      > 07_bin_qc/${i}_medium_quality_MAG_list.txt

    # Select high-quality MAGs:
    # completeness >= 90% and contamination <= 5%
    awk -F'\t' 'NR==1 {next} $2>=90 && $3<=5 {print $1}' \
      07_bin_qc/${i}_checkm2/quality_report.tsv \
      > 07_bin_qc/${i}_high_quality_MAG_list.txt

    # Copy medium-quality MAGs
    while read bin
    do
      cp 06_binning/${i}_bins/${bin}.fa \
         07_bin_qc/${i}_selected_MAGs/
    done < 07_bin_qc/${i}_medium_quality_MAG_list.txt

    # Copy high-quality MAGs
    while read bin
    do
      cp 06_binning/${i}_bins/${bin}.fa \
         07_bin_qc/${i}_high_quality_MAGs/
    done < 07_bin_qc/${i}_high_quality_MAG_list.txt

Explanation:

This step selects MAGs based on common quality criteria:

    Medium-quality MAGs: completeness >= 50% and contamination <= 10%
    High-quality MAGs: completeness >= 90% and contamination <= 5%

For downstream SGB construction and phylogenetic analysis, medium-quality and high-quality MAGs are generally more reliable than all raw bins.

Main outputs:

    07_bin_qc/${i}_selected_MAGs
    07_bin_qc/${i}_high_quality_MAGs

Note:

The column order of `quality_report.tsv` may vary slightly among CheckM2 versions. If the MAG filtering step fails, check the column names manually using:

    head 07_bin_qc/${i}_checkm2/quality_report.tsv

# 7. Taxonomic annotation of bins

## 7.1 Taxonomic classification of MAGs using GTDB-Tk

    # Activate the conda environment containing GTDB-Tk
    conda activate gtdbtk

    # Configure GTDB-Tk database
    export GTDBTK_DATA_PATH=${GTDBTK_DB}

    # Check whether GTDB-Tk and databases are properly configured
    gtdbtk check_install

    # Run GTDB-Tk classification workflow
    gtdbtk classify_wf \
      --genome_dir 07_bin_qc/${i}_selected_MAGs \
      --extension fa \
      --out_dir 08_bin_taxonomy/${i}_gtdbtk \
      --cpus ${threads} \
      --skip_ani_screen

Explanation:

GTDB-Tk assigns standardized bacterial and archaeal taxonomy to MAGs based on the GTDB reference database. The option `--skip_ani_screen` can speed up the analysis, but it can be removed when accurate species-level placement is required.

Main output directory:

    08_bin_taxonomy/${i}_gtdbtk

## 7.2 Convert GTDB-Tk tree to iTOL format

    # Convert GTDB-Tk tree to iTOL-compatible format if tree file is available
    gtdbtk convert_to_itol \
      --input 08_bin_taxonomy/${i}_gtdbtk/gtdbtk.bac120.classify.tree \
      --output 08_bin_taxonomy/${i}_gtdbtk/${i}_gtdbtk_itol.tree

Explanation:

The converted tree can be uploaded to iTOL for visualization and annotation. If GTDB-Tk does not generate this tree file in your version, this step can be skipped.

# 8. SGB construction and SGB phylogenetic analysis

## 8.1 Collect selected MAGs for SGB construction

    # Activate the conda environment containing Mash
    conda activate mash

    # Copy selected MAGs into the SGB analysis directory
    cp 07_bin_qc/${i}_selected_MAGs/*.fa \
       09_SGBs/MAGs/

    # Generate MAG list
    find 09_SGBs/MAGs \
      -name "*.fa" \
      > 09_SGBs/all_MAGs.txt

Explanation:

This step collects medium-quality and high-quality MAGs for SGB construction. SGB analysis should preferably be performed on quality-controlled MAGs rather than all raw bins.

Main output:

    09_SGBs/all_MAGs.txt

## 8.2 Build Mash sketches for all MAGs

    # Build Mash sketches for MAGs
    mash sketch \
      -o 09_SGBs/MAGs_sketch \
      -k 21 \
      -s 10000 \
      09_SGBs/MAGs/*.fa

Explanation:

Mash converts genome sequences into compact sketches and enables rapid pairwise genome distance estimation.

Main output:

    09_SGBs/MAGs_sketch.msh

## 8.3 Calculate pairwise Mash distances

    # Calculate pairwise Mash distances among MAGs
    mash dist \
      09_SGBs/MAGs_sketch.msh \
      09_SGBs/MAGs_sketch.msh \
      -p ${threads} \
      > 09_SGBs/mash_distances.tab

Explanation:

This step calculates pairwise Mash distances among all selected MAGs.

Main output:

    09_SGBs/mash_distances.tab

## 8.4 Extract similar MAG pairs for SGB clustering

    # Extract MAG pairs with Mash distance <= 0.05
    # This threshold approximately corresponds to genome similarity >= 95%
    awk '$3 <= 0.05 {print $1"\t"$2}' \
      09_SGBs/mash_distances.tab \
      > 09_SGBs/similar_pairs.tsv

Explanation:

A Mash distance threshold of 0.05 is used as an approximate species-level boundary. For publication-level SGB definition, FastANI or dRep-based ANI clustering is recommended for further confirmation.

Main output:

    09_SGBs/similar_pairs.tsv

## 8.5 Cluster MAGs into SGBs

    # Generate Python script for graph-based SGB clustering
    cat > 09_SGBs/scripts/cluster_sgbs.py << 'PYEOF'
    #!/usr/bin/env python3

    import argparse
    import networkx as nx

    parser = argparse.ArgumentParser(description="Cluster MAGs into SGBs based on Mash distance.")
    parser.add_argument("--mag-list", required=True, help="File containing all MAG paths.")
    parser.add_argument("--pairs", required=True, help="TSV file containing similar MAG pairs.")
    parser.add_argument("--out", required=True, help="Output SGB clustering table.")
    args = parser.parse_args()

    G = nx.Graph()

    with open(args.mag_list) as f:
        for line in f:
            mag = line.strip()
            if mag:
                G.add_node(mag)

    with open(args.pairs) as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            a, b = line.split()[:2]
            G.add_edge(a, b)

    clusters = list(nx.connected_components(G))

    with open(args.out, "w") as out:
        out.write("SGB_ID\tRepresentative_MAG\tCluster_Size\tMAG\n")
        for idx, cluster in enumerate(clusters, start=1):
            files_sorted = sorted(cluster)
            rep = files_sorted[0]
            sgb_id = f"SGB_{idx:05d}"
            for mag in files_sorted:
                out.write(f"{sgb_id}\t{rep}\t{len(files_sorted)}\t{mag}\n")

    print(f"Total SGBs: {len(clusters)}")
    print(f"SGB clustering results written to {args.out}")
    PYEOF

    # Make the script executable
    chmod +x 09_SGBs/scripts/cluster_sgbs.py

    # Activate Python environment containing networkx
    conda activate python

    # Run SGB clustering
    python 09_SGBs/scripts/cluster_sgbs.py \
      --mag-list 09_SGBs/all_MAGs.txt \
      --pairs 09_SGBs/similar_pairs.tsv \
      --out 09_SGBs/SGB_clusters.tsv

Explanation:

This script performs graph-based SGB clustering. Each MAG is treated as a node. MAG pairs with Mash distance ≤ 0.05 are connected by edges. Connected components are defined as SGBs. Singleton MAGs are also retained as independent SGBs.

Main output:

    09_SGBs/SGB_clusters.tsv

## 8.6 Extract representative MAGs for each SGB

    # Extract representative MAGs
    cut -f2 09_SGBs/SGB_clusters.tsv | \
      tail -n +2 | \
      sort | \
      uniq \
      > 09_SGBs/representative_MAGs.txt

    # Copy representative MAGs to a separate directory
    while read mag
    do
      cp ${mag} 09_SGBs/repre_MAGs/
    done < 09_SGBs/representative_MAGs.txt

Explanation:

This step extracts one representative MAG from each SGB for phylogenetic tree construction.

Main outputs:

    09_SGBs/representative_MAGs.txt
    09_SGBs/repre_MAGs/

## 8.7 Phylogenetic tree construction for representative SGBs using PhyloPhlAn

    # Activate the conda environment containing PhyloPhlAn
    conda activate phylophlan

    # Construct phylogenetic tree for representative SGBs
    phylophlan \
      -i 09_SGBs/repre_MAGs/ \
      --diversity high \
      -d ${PHYLOPHLAN_DB} \
      --fast \
      --min_num_markers 50 \
      --nproc ${threads} \
      -o 10_SGB_tree/${i}_repre_MAGs_phylophlan \
      -f ${PHYLOPHLAN_CFG} \
      --genome_extension fa

Explanation:

PhyloPhlAn constructs a phylogenetic tree based on conserved marker genes from representative MAGs. This tree can be used to display the evolutionary relationships among SGBs.

Main output directory:

    10_SGB_tree/${i}_repre_MAGs_phylophlan

# 9. Recommended final output structure

    ${i}_short_read_metagenome/
    ├── 01_raw_qc
    ├── 02_clean_reads
    ├── 03_taxonomy
    ├── 04_ARGs
    ├── 05_assembly
    ├── 06_binning
    ├── 07_bin_qc
    ├── 08_bin_taxonomy
    ├── 09_SGBs
    └── 10_SGB_tree

Explanation:

This directory structure keeps each analysis module independent and makes it easier to check intermediate results, repeat failed steps and prepare figures or supplementary tables.

# 10. Example command summary

## 10.1 Prepare sample name

    i=sample_name
    threads=24
    raw_R1=${i}_R1.fastq.gz
    raw_R2=${i}_R2.fastq.gz

## 10.2 Run major modules sequentially

    # 1. Raw data quality control
    # fastp quality filtering and clean read statistics

    # 2. Read-based taxonomic profiling
    # Kraken2 and Bracken

    # 3. ARG annotation and quantification
    # ARGs_OAP stage one and stage two

    # 4. Metagenomic assembly
    # MEGAHIT

    # 5. Genome binning
    # MetaWRAP MetaBAT2

    # 6. Bin quality assessment
    # CheckM2

    # 7. Bin taxonomy
    # GTDB-Tk

    # 8. SGB construction and phylogenetic analysis
    # Mash + graph clustering + PhyloPhlAn

# 11. Notes for publication-level analysis

## 11.1 Database and software versions

    # Recommended version recording commands
    fastp --version
    seqkit version
    kraken2 --version
    bracken -h
    args_oap -h
    megahit --version
    metawrap -h
    checkm2 --version
    gtdbtk --version
    mash --version
    phylophlan --version

Explanation:

For manuscript preparation, software versions and database versions should be recorded to ensure reproducibility.

## 11.2 Suggested MAG quality criteria

    # High-quality MAGs:
    # completeness >= 90% and contamination <= 5%

    # Medium-quality MAGs:
    # completeness >= 50% and contamination <= 10%

Explanation:

These criteria are commonly used for MAG quality assessment. For SGB construction and phylogenetic tree analysis, using medium-quality and high-quality MAGs is recommended.

## 11.3 Suggested SGB definition strategy

    # Fast strategy:
    # Mash distance <= 0.05

    # More rigorous strategy:
    # ANI >= 95% using FastANI, dRep or skani

Explanation:

Mash-based clustering is fast and useful for exploratory analysis. For formal publication-level SGB definition, ANI-based verification is recommended.
