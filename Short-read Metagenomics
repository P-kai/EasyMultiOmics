#!/bin/bash

# EasyMultiOmics: Short-read metagenomic analysis workflow
# Module: Short-read Metagenomics
# Description: Quality control, taxonomic profiling, ARG annotation and quantification, assembly, binning, bin quality control, bin taxonomy, and MAG phylogeny

sample=$1
threads=24

R1=${sample}_R1.fastq.gz
R2=${sample}_R2.fastq.gz

mkdir -p QC
mkdir -p Taxonomy
mkdir -p ARGs
mkdir -p Assembly
mkdir -p Binning
mkdir -p Bin_QC
mkdir -p Bin_Taxonomy
mkdir -p MAG_Tree


# ============================================================
# Raw data quality control
# ============================================================

conda activate fastp

fastp \
  -i ${R1} \
  -I ${R2} \
  -o QC/${sample}_clean_R1.fastq.gz \
  -O QC/${sample}_clean_R2.fastq.gz \
  -h QC/${sample}_fastp.html \
  -j QC/${sample}_fastp.json \
  -w ${threads}


# ============================================================
# Read-based taxonomic profiling
# ============================================================

conda activate kraken2

kraken2 \
  --db /path/to/kraken2_database \
  --threads ${threads} \
  --paired \
  --gzip-compressed \
  --report Taxonomy/${sample}_kraken2_report.txt \
  --output Taxonomy/${sample}_kraken2_output.txt \
  QC/${sample}_clean_R1.fastq.gz \
  QC/${sample}_clean_R2.fastq.gz

conda activate bracken

bracken \
  -d /path/to/kraken2_database \
  -i Taxonomy/${sample}_kraken2_report.txt \
  -o Taxonomy/${sample}_bracken_species.txt \
  -r 150 \
  -l S \
  -t ${threads}


# ============================================================
# ARG annotation and quantification using ARGs_OAP
# ============================================================

conda activate args_oap

mkdir -p ARGs/${sample}_ARGs_OAP
mkdir -p ARGs/${sample}_ARGs_OAP/stage_one
mkdir -p ARGs/${sample}_ARGs_OAP/stage_two

# Input files for ARGs_OAP
# ARGs_OAP supports fasta format input in this workflow.
# If your input files are fastq.gz, please convert them to fasta first.

seqkit fq2fa QC/${sample}_clean_R1.fastq.gz > ARGs/${sample}_R1.clean.fa
seqkit fq2fa QC/${sample}_clean_R2.fastq.gz > ARGs/${sample}_R2.clean.fa

cat ARGs/${sample}_R1.clean.fa ARGs/${sample}_R2.clean.fa > ARGs/${sample}_clean_reads.fa


# Optional: build customized ARGs_OAP database
# Use this step only when using a customized database.
# The database can contain nucleotide or amino acid sequences.

# args_oap make_db \
#   -i /path/to/custom_database.fasta


# Stage one: ARG annotation using ARGs_OAP

args_oap stage_one \
  -i ARGs/${sample}_clean_reads.fa \
  -o ARGs/${sample}_ARGs_OAP/stage_one \
  -f fa \
  -t ${threads} \
  --database /path/to/database.fasta


# Stage two: ARG classification and quantification using ARGs_OAP

args_oap stage_two \
  -i ARGs/${sample}_ARGs_OAP/stage_one \
  -t ${threads} \
  --database /path/to/database.fasta \
  --structure1 /path/to/structure.txt

# ============================================================
# Metagenomic assembly
# ============================================================

conda activate megahit

megahit \
  -1 QC/${sample}_clean_R1.fastq.gz \
  -2 QC/${sample}_clean_R2.fastq.gz \
  -o Assembly/${sample}_megahit \
  -t ${threads} \
  --min-contig-len 1000

cp Assembly/${sample}_megahit/final.contigs.fa Assembly/${sample}_contigs.fa


# ============================================================
# Genome binning using MetaWRAP MetaBAT2
# ============================================================

conda activate metawrap

mkdir -p Binning/${sample}_metawrap_metabat2

metawrap binning \
  -o Binning/${sample}_metawrap_metabat2 \
  -t ${threads} \
  -a Assembly/${sample}_contigs.fa \
  --metabat2 \
  QC/${sample}_clean_R1.fastq.gz \
  QC/${sample}_clean_R2.fastq.gz


# ============================================================
# Bin quality assessment using CheckM2
# ============================================================

conda activate checkm2

checkm2 predict \
  --threads ${threads} \
  --input Binning/${sample}_metawrap_metabat2/metabat2_bins \
  --output-directory Bin_QC/${sample}_checkm2 \
  -x fa


# ============================================================
# Taxonomic annotation of bins using GTDB-Tk
# ============================================================

conda activate gtdbtk

export GTDBTK_DATA_PATH=/path/to/gtdbtk_database

gtdbtk classify_wf \
  --genome_dir Binning/${sample}_metawrap_metabat2/metabat2_bins \
  --extension fa \
  --out_dir Bin_Taxonomy/${sample}_gtdbtk \
  --cpus ${threads} \
  --skip_ani_screen

# ============================================================
# SGB construction based on Mash distance
# ============================================================

conda activate mash

mkdir -p SGBs
mkdir -p SGBs/MAGs
mkdir -p SGBs/repre_MAGs
mkdir -p SGBs/scripts

# Copy high-quality or selected MAGs into SGBs/MAGs
# Please modify the input path according to your binning results
cp Binning/${sample}_metawrap_metabat2/metabat2_bins/*.fa SGBs/MAGs/


# Build Mash sketches for all MAGs

mash sketch \
  -o SGBs/MAGs_sketch \
  -k 21 \
  -s 10000 \
  SGBs/MAGs/*.fa


# Calculate pairwise Mash distances

mash dist \
  SGBs/MAGs_sketch.msh \
  SGBs/MAGs_sketch.msh \
  -p ${threads} \
  > SGBs/mash_distances.tab


# Extract similar MAG pairs with Mash distance <= 0.05
# This threshold corresponds approximately to genome similarity >= 95%

awk '$3<=0.05 {print $1"\t"$2}' \
  SGBs/mash_distances.tab \
  > SGBs/similar_pairs.tsv


# ============================================================
# Cluster MAGs into SGBs
# ============================================================

cat > SGBs/scripts/cluster_sgbs.py << 'EOF'
#!/usr/bin/env python3

import networkx as nx
import argparse

def main():
    parser = argparse.ArgumentParser(description="Cluster MAGs into SGBs based on pairwise Mash similarity.")
    parser.add_argument("-i", "--input", required=True, help="Input file containing similar MAG pairs in TSV format.")
    parser.add_argument("-o", "--output", required=True, help="Output file for SGB clustering results.")
    args = parser.parse_args()

    edges = []

    with open(args.input) as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            a, b = line.split()[:2]
            edges.append((a, b))

    G = nx.Graph()
    G.add_edges_from(edges)

    clusters = list(nx.connected_components(G))

    with open(args.output, "w") as out:
        out.write("Representative_MAG\tCluster_Size\tFiles\n")
        for cluster in clusters:
            rep = sorted(cluster)[0]
            cluster_size = len(cluster)
            files_sorted = sorted(cluster)
            for mag in files_sorted:
                out.write(f"{rep}\t{cluster_size}\t{mag}\n")

    print(f"Total SGBs: {len(clusters)}")
    print(f"SGB clustering results written to {args.output}")

if __name__ == "__main__":
    main()
EOF

chmod +x SGBs/scripts/cluster_sgbs.py


# Run SGB clustering

conda activate python

python SGBs/scripts/cluster_sgbs.py \
  -i SGBs/similar_pairs.tsv \
  -o SGBs/SGB_clusters.tsv


# Extract representative MAGs for each SGB

cut -f1 SGBs/SGB_clusters.tsv | tail -n +2 | sort | uniq > SGBs/representative_MAGs.txt

while read mag
do
  cp ${mag} SGBs/repre_MAGs/
done < SGBs/representative_MAGs.txt


# ============================================================
# Phylogenetic tree construction for representative SGBs
# ============================================================

conda activate phylophlan

phylophlan \
  -i SGBs/repre_MAGs/ \
  --diversity high \
  -d phylophlan_databases/phylophlan \
  --fast \
  --min_num_markers 50 \
  --nproc ${threads} \
  -o SGBs/repre_MAGs_phylophlan \
  -f /ifs1/Software/Miniconda3/envs/phylophlan/lib/python3.13/site-packages/phylophlan/phylophlan_configs/supermatrix_aa.cfg \
  --genome_extension fa
